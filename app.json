{
  "expo": {
    "name": "Jamindar",
    "slug": "jamindar-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "scheme": "jamindar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.jamindar.mobile"
    },
    "android": {
      "package": "app.jamindar.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#E11B22"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Jamindar uses your location to show nearby properties."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Jamindar voice assistant needs the microphone to hear you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://zmxqozvivdluuxvvcegs.supabase.co",
      "supabaseAnonKey": "sb_publishable_7Oe-H5Ekn7FaS9c0pVbrVQ_ph9LHHsS",
      "router": {},
      "eas": {
        "projectId": "cdf51b8f-05c0-4627-a074-33d9a13b11eb"
      }
    },
    "owner": "abetrex"
  }
}
