# Client config is read from app.json → expo.extra (safe publishable key only).
# These server-side secrets are set as Supabase Edge Function env vars or in the
# app_secrets table — never bundle them into the mobile client.

# Jamindar voice (stored in app_secrets.SARVAM_API_KEY)
SARVAM_API_KEY=

# Production OTP SMS via MSG91 (edge-function env)
MSG91_AUTHKEY=
MSG91_TEMPLATE_ID=

# OTP hashing pepper (edge-function env)
OTP_PEPPER=

# Set to "true" to return the OTP in the response for local testing
OTP_DEV_MODE=true
